# Agent-Fox self-development container
#
# Installs a frozen copy of agent-fox (v2.2.1) from GitHub as the EXECUTOR.
# The workspace repo is bind-mounted at /workspace at runtime, keeping the
# running agent-fox code completely separate from the code it edits.
#
# Build:  podman build -t agent-fox-dev -f scripts/self-dev/Containerfile .
# Run:    see scripts/self-dev/podman-compose.yml

# ── Stage 1: build agent-fox from a pinned tag ──────────────────────────
FROM python:3.12-slim AS builder

RUN apt-get update && apt-get install -y --no-install-recommends git && \
    rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir uv

ARG AF_VERSION=v2.2.1
ARG AF_REPO=https://github.com/agent-fox-dev/agent-fox-v2.git

WORKDIR /build
RUN git clone --depth 1 --branch "${AF_VERSION}" "${AF_REPO}" . && \
    uv venv /opt/agent-fox-venv && \
    VIRTUAL_ENV=/opt/agent-fox-venv uv pip install .

# ── Stage 2: runtime image (Red Hat UBI 9 / Python 3.12) ────────────────
FROM registry.access.redhat.com/ubi9/python-312

USER root

# System dependencies (UBI uses dnf/microdnf)
RUN dnf install -y --nodocs \
        git \
        make \
        openssh-clients \
    && dnf clean all

# Node.js 22 (required for Claude Code CLI)
RUN dnf module enable -y nodejs:22 && \
    dnf install -y --nodocs nodejs && \
    dnf clean all

# Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# uv (needed for `make check` etc. in the workspace)
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Copy the frozen agent-fox venv from the builder stage and fix the
# Python symlinks so they resolve against the UBI system Python.
COPY --from=builder /opt/agent-fox-venv /opt/agent-fox-venv
RUN ln -sf "$(command -v python3)" /opt/agent-fox-venv/bin/python3 && \
    ln -sf "$(command -v python3)" /opt/agent-fox-venv/bin/python

# Put agent-fox on PATH (the venv's bin has the `agent-fox` entry point)
ENV PATH="/opt/agent-fox-venv/bin:${PATH}" \
    VIRTUAL_ENV=/opt/agent-fox-venv

# Set up non-root user home directory
ENV HOME=/home/agent-fox
RUN mkdir -p /home/agent-fox /workspace && \
    chown -R 1001:0 /home/agent-fox /workspace

WORKDIR /workspace

# Verify the executor is functional
RUN agent-fox --version

# Run as non-root (UBI default user is 1001)
USER 1001

ENTRYPOINT ["agent-fox"]
