#!/usr/bin/env bash
set -euo pipefail

# Run the production (main branch) version of agent-fox via uvx.
# This avoids conflicts with any local development checkout.
#
#   af code --project ~/projects/my-app   # normal usage
#   af update                             # pull latest main

AF_FROM="git+https://github.com/agent-fox-dev/agent-fox-v2.git@main"

if [[ "${1:-}" == "update" ]]; then
    echo "Updating af → agent-fox@main …"
    uvx --refresh --from "$AF_FROM" agent-fox --version
    echo "Done."
    exit
fi

exec uvx --from "$AF_FROM" agent-fox "$@"
